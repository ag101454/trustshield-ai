{
    "manifest_version": 3,
    "name": "TrustShield AI - Website Safety Check",
    "version": "1.0.0",
    "description": "Real-time website safety ratings. Check any website for scams, phishing, and malware before you browse.",
    "permissions": [
      "activeTab",
      "storage",
      "tabs",
      "notifications"
    ],
    "host_permissions": [
      "https://trustshield-ai.vercel.app/*",
      "http://localhost:5173/*"
    ],
    "action": {
      "default_popup": "popup.html",
      "default_icon": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
      },
      "default_title": "TrustShield AI - Check this site"
    },
    "icons": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "background": {
      "service_worker": "background.js"
    },
    "content_scripts": [
      {
        "matches": ["<all_urls>"],
        "js": ["content.js"],
        "css": ["badge.css"],
        "run_at": "document_end"
      }
    ],
    "web_accessible_resources": [
      {
        "resources": ["icons/*"],
        "matches": ["<all_urls>"]
      }
    ]
  }